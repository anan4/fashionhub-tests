    "test:local": "cross-env LOCAL_BASE_URL=http://localhost:4000/fashionhub/ playwright test --project=local-chromium",
    "test:staging-as-prod": "cross-env STAGING_BASE_URL=https://pocketaces2.github.io/fashionhub/ playwright test --project=staging-chromium"
